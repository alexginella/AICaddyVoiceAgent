# === LiveKit Cloud (required) ===
# Get from https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# === OpenAI (required for agent LLM + RAG embeddings) ===
OPENAI_API_KEY=sk-your_openai_key

# === Golf Course API (required to generate yardage books in Course Guide Service) ===
# https://golfcourseapi.com — put only the key here; the app sends: Authorization: Key <value>
GOLF_COURSE_API_KEY=your_golf_course_api_key

# === Frontend (for local dev; also set on Vercel at build time) ===
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# === Course Guide Service base URL ===
# Local: default http://127.0.0.1:8765 if unset (api-server.js).
# Vercel: required — public HTTPS origin of the deployed guide (no path; /api/ensure-guide proxies to .../ensure-guide).
# GUIDE_SERVICE_URL=http://127.0.0.1:8765

# === Voice agent (LiveKit worker / local agent; not used by Vercel frontend build) ===
# CADDY_VOICE_INFERENCE=openai
